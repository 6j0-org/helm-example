apiVersion: postgresql.cnpg.io/v1
kind: Cluster
metadata:
  name: keycloak-db
  namespace: keycloak
spec:
  bootstrap:
    initdb:
      database: bitnami_keycloak
      owner: bn_keycloak
      secret:
        name: keycloak-db-app-secret
  instances: 3
  storage:
    size: 1Gi
  superuserSecret:
    name: keycloak-db-superuser-secret
